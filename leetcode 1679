from collections import Counter

class Solution:
    def maxOperations(self, nums: list[int], k: int) -> int:
        freq = Counter(nums)
        operations = 0

        for num in list(freq.keys()):
            complement = k - num

            if num == complement:
                # Pairs formed within the same number
                operations += freq[num] // 2
            elif complement in freq:
                # Pairs formed between num and complement
                pairs = min(freq[num], freq[complement])
                operations += pairs
                freq[complement] = 0

            freq[num] = 0

        return operations
